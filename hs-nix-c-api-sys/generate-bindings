#!/usr/bin/env bash
set -euo pipefail

# Generate Haskell FFI bindings from the Nix C API headers using hs-bindgen.
# Headers are processed in dependency order, with binding specs to prevent
# type duplication across modules.

OUTDIR="src"
SPECDIR="binding-specs"
mkdir -p "${SPECDIR}"

generate() {
  local module="$1"
  local header="$2"
  shift 2

  local unique_id="org.cachix.hs-nix-c-api.$(echo "${module}" | tr '.' '-' | tr '[:upper:]' '[:lower:]')"

  echo "Generating ${module} from ${header}..."
  hs-bindgen-cli preprocess \
    --module="${module}" \
    --unique-id="${unique_id}" \
    --hs-output-dir="${OUTDIR}" \
    --enable-program-slicing \
    --select-except-deprecated \
    "$@" \
    "${header}"
}

# --- Layer 1: libutil-c (no dependencies) ---

generate Generated.Nix.Util nix_api_util.h \
  --gen-binding-spec="${SPECDIR}/NixUtil.yaml"

# --- Layer 2: libstore-c (depends on util) ---

generate Generated.Nix.Store.Path nix_api_store/store_path.h \
  --external-binding-spec="${SPECDIR}/NixUtil.yaml" \
  --gen-binding-spec="${SPECDIR}/NixStorePath.yaml"

generate Generated.Nix.Store.Derivation nix_api_store/derivation.h \
  --external-binding-spec="${SPECDIR}/NixUtil.yaml" \
  --gen-binding-spec="${SPECDIR}/NixStoreDerivation.yaml"

generate Generated.Nix.Store nix_api_store.h \
  --external-binding-spec="${SPECDIR}/NixUtil.yaml" \
  --external-binding-spec="${SPECDIR}/NixStorePath.yaml" \
  --external-binding-spec="${SPECDIR}/NixStoreDerivation.yaml" \
  --gen-binding-spec="${SPECDIR}/NixStore.yaml"

# --- Layer 3: libexpr-c (depends on util, store) ---

generate Generated.Nix.Value nix_api_value.h \
  --external-binding-spec="${SPECDIR}/NixUtil.yaml" \
  --external-binding-spec="${SPECDIR}/NixStorePath.yaml" \
  --external-binding-spec="${SPECDIR}/NixStoreDerivation.yaml" \
  --external-binding-spec="${SPECDIR}/NixStore.yaml" \
  --gen-binding-spec="${SPECDIR}/NixValue.yaml"

generate Generated.Nix.Expr nix_api_expr.h \
  --external-binding-spec="${SPECDIR}/NixUtil.yaml" \
  --external-binding-spec="${SPECDIR}/NixStorePath.yaml" \
  --external-binding-spec="${SPECDIR}/NixStoreDerivation.yaml" \
  --external-binding-spec="${SPECDIR}/NixStore.yaml" \
  --external-binding-spec="${SPECDIR}/NixValue.yaml" \
  --gen-binding-spec="${SPECDIR}/NixExpr.yaml"

generate Generated.Nix.External nix_api_external.h \
  --external-binding-spec="${SPECDIR}/NixUtil.yaml" \
  --external-binding-spec="${SPECDIR}/NixStorePath.yaml" \
  --external-binding-spec="${SPECDIR}/NixStoreDerivation.yaml" \
  --external-binding-spec="${SPECDIR}/NixStore.yaml" \
  --external-binding-spec="${SPECDIR}/NixValue.yaml" \
  --external-binding-spec="${SPECDIR}/NixExpr.yaml" \
  --gen-binding-spec="${SPECDIR}/NixExternal.yaml"

# --- Layer 4: libfetchers-c (depends on util) ---

generate Generated.Nix.Fetchers nix_api_fetchers.h \
  --external-binding-spec="${SPECDIR}/NixUtil.yaml" \
  --gen-binding-spec="${SPECDIR}/NixFetchers.yaml"

# --- Layer 5: libflake-c (depends on util, store, expr, fetchers) ---

generate Generated.Nix.Flake nix_api_flake.h \
  --external-binding-spec="${SPECDIR}/NixUtil.yaml" \
  --external-binding-spec="${SPECDIR}/NixStorePath.yaml" \
  --external-binding-spec="${SPECDIR}/NixStoreDerivation.yaml" \
  --external-binding-spec="${SPECDIR}/NixStore.yaml" \
  --external-binding-spec="${SPECDIR}/NixValue.yaml" \
  --external-binding-spec="${SPECDIR}/NixExpr.yaml" \
  --external-binding-spec="${SPECDIR}/NixFetchers.yaml" \
  --gen-binding-spec="${SPECDIR}/NixFlake.yaml"

# --- Layer 6: libmain-c (depends on util) ---

generate Generated.Nix.Main nix_api_main.h \
  --external-binding-spec="${SPECDIR}/NixUtil.yaml"

echo "Done. Generated bindings are in ${OUTDIR}/Generated/"
echo "Binding specs are in ${SPECDIR}/"
